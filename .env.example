NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side AI. Choose one provider and configure only its secret key.
# Supported values: gemini, groq, openrouter, huggingface, mock
AI_PROVIDER=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=

# Optional model overrides. Leave blank to use the app defaults.
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# OPENROUTER_MODEL=openrouter/free
# HUGGINGFACE_MODEL=zai-org/GLM-4.5V:fastest

# Optional OpenRouter attribution header.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Puter.js remains available as a separate client-side option and does not
# need an API key. The user authorizes Puter directly in the browser.

# Optional compatibility with the new Supabase publishable key name.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# The current app does not require a service role key.
# If you add server-only admin APIs later, use this name only on the server:
# SUPABASE_SERVICE_ROLE_KEY=
