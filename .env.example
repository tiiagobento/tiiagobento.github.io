NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Puter.js does not need an environment variable. The AI import page loads
# https://js.puter.com/v2/ in the browser and the user authorizes Puter there.

# Optional compatibility with the new Supabase publishable key name.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# The current app does not require a service role key.
# If you add server-only admin APIs later, use this name only on the server:
# SUPABASE_SERVICE_ROLE_KEY=
